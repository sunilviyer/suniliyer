{
  "redirects": [
    {
      "source": "/aidefence/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/seshan/demo/",
      "destination": "/coming-soon",
      "permanent": false
    },
    {
      "source": "/seshan/dashboard/",
      "destination": "/coming-soon",
      "permanent": false
    }
  ],
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
